    <script is:inline
      data-brevo-key={import.meta.env.PUBLIC_BREVO_API_KEY}
      data-brevo-list="9"
    >
      const scriptEl = document.currentScript;
      const BREVO_API_KEY = scriptEl.getAttribute('data-brevo-key') || '';
      const BREVO_LIST_ID = 9;

      document.querySelectorAll('#email-form-1, #email-form-2').forEach(form => {
        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          const email = this.querySelector('input[name="email"]').value;
          const btn = this.querySelector('button[type="submit"]');
          btn.disabled = true;
          btn.textContent = 'Sending...';

          try {
            const res = await fetch("https://api.brevo.com/v3/contacts", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "api-key": BREVO_API_KEY,
              },
              body: JSON.stringify({
                email: email,
                listIds: [BREVO_LIST_ID],
                updateEnabled: true,
              }),
            });

            if (!res.ok && res.status !== 204) {
              throw new Error('Brevo subscribe failed');
            }

            this.innerHTML = '<div class="text-emerald-400 font-semibold py-3">Check your inbox! Your playbook is on its way.</div>';
          } catch (err) {
            console.error('Brevo subscription failed:', err);
            btn.disabled = false;
            btn.textContent = 'Get the Playbook';
          }
        });
      });

      // Video placeholder click handler
      const videoContainer = document.getElementById('video-container');
      const videoPlaceholder = document.getElementById('video-placeholder');
      if (videoContainer && videoPlaceholder) {
        videoContainer.addEventListener('click', function() {
          // TODO: Replace with your actual video embed (Wistia, Vimeo, YouTube)
          // Example with YouTube:
          // videoPlaceholder.innerHTML = '<iframe class="absolute inset-0 w-full h-full" src="https://www.youtube.com/embed/YOUR_VIDEO_ID?autoplay=1" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>';

          // For now, show a message
          videoPlaceholder.innerHTML = '<p class="text-muted-foreground text-sm">Video embed goes here.<br/>Replace with your Wistia, Vimeo, or YouTube embed.</p>';
        });
      }

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    </script>

