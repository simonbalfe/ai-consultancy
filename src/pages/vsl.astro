---
import BaseHead from "@/components/BaseHead.astro";
import { CALENDLY_URL } from "../consts";
---

<html lang="en" class="dark">
  <head>
    <BaseHead
      title="Free Training: How Businesses Are Saving 15+ Hours Per Week With Custom AI Systems"
      description="Watch this free training to discover how businesses are automating their operations with custom AI systems and saving 15+ hours per person per week."
    />
    <script is:inline>
      (() => {
        document.documentElement.classList.add("dark");
      })();
    </script>
  </head>
  <body class="antialiased bg-background text-foreground">

    <!-- STICKY CTA BAR (mobile) -->
    <div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-background/95 backdrop-blur-sm border-t border-border px-4 py-3">
      <a
        href="#get-access"
        class="block w-full bg-emerald-500 text-white text-center py-3.5 rounded-full text-sm font-semibold hover:bg-emerald-400 transition-colors"
      >
        Get Instant Access
      </a>
    </div>

    <!-- HERO -->
    <section class="pt-12 md:pt-20 pb-8 px-6">
      <div class="max-w-4xl mx-auto text-center">

        <!-- Social proof bar -->
        <div class="flex items-center justify-center gap-2 mb-8">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-muted border-2 border-background flex items-center justify-center text-xs font-bold text-muted-foreground">S</div>
            <div class="w-8 h-8 rounded-full bg-muted border-2 border-background flex items-center justify-center text-xs font-bold text-muted-foreground">J</div>
            <div class="w-8 h-8 rounded-full bg-muted border-2 border-background flex items-center justify-center text-xs font-bold text-muted-foreground">M</div>
            <div class="w-8 h-8 rounded-full bg-muted border-2 border-background flex items-center justify-center text-xs font-bold text-muted-foreground">R</div>
          </div>
          <p class="text-sm text-muted-foreground">
            Trusted by <span class="text-foreground font-medium">50+ businesses</span> across the UK
          </p>
        </div>

        <!-- Headline -->
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-5">
          How businesses are saving<br/>
          <span class="text-emerald-400">15+ hours per week</span><br/>
          with custom AI systems
        </h1>

        <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto mb-8">
          Watch this free training to see the exact systems we build to eliminate repetitive tasks, automate operations, and give teams their time back.
        </p>

        <!-- Urgency badge -->
        <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-4 py-1.5 mb-10">
          <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
          <span class="text-sm text-emerald-400 font-medium">Free training available for a limited time</span>
        </div>
      </div>
    </section>

    <!-- VIDEO -->
    <section class="px-6 pb-12">
      <div class="max-w-3xl mx-auto">
        <div class="relative aspect-video bg-card border border-border rounded-2xl overflow-hidden group cursor-pointer" id="video-container">
          <!-- Video placeholder / thumbnail -->
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-4" id="video-placeholder">
            <div class="w-20 h-20 rounded-full bg-emerald-500 flex items-center justify-center group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <p class="text-sm text-muted-foreground">Click to play the training</p>
          </div>
          <!-- Video embed will be inserted here by JS -->
        </div>
        <p class="text-center text-xs text-muted-foreground mt-3">No signup required to watch. Enter your email below for the full breakdown.</p>
      </div>
    </section>

    <!-- EMAIL CAPTURE (Primary) -->
    <section id="get-access" class="py-16 px-6 bg-card">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-3">
          Get the full AI automation breakdown
        </h2>
        <p class="text-muted-foreground mb-8">
          Enter your email to receive the complete playbook: which tasks to automate first, expected time savings, and a custom system blueprint for your business.
        </p>

        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" id="email-form-1">
          <input
            type="email"
            name="email"
            required
            placeholder="Your work email"
            class="flex-1 bg-background border border-border rounded-full px-5 py-3.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500/50"
          />
          <button
            type="submit"
            class="bg-emerald-500 text-white px-6 py-3.5 rounded-full text-sm font-semibold hover:bg-emerald-400 transition-colors whitespace-nowrap"
          >
            Get Instant Access
          </button>
        </form>

        <p class="text-xs text-muted-foreground mt-4">No spam. Unsubscribe anytime. Your data stays private.</p>
      </div>
    </section>

    <!-- PROBLEM AGITATION -->
    <section class="py-20 px-6">
      <div class="max-w-3xl mx-auto">
        <p class="text-emerald-400 text-sm font-medium tracking-wide uppercase mb-4">The problem</p>
        <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-8">
          Your team is drowning in tasks<br/>
          <span class="text-muted-foreground">that should not need a human.</span>
        </h2>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <div>
              <p class="font-medium mb-1">Hours lost to CRM updates, data entry, and manual follow-ups</p>
              <p class="text-muted-foreground text-sm">Your highest-paid people are doing your lowest-value work.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <div>
              <p class="font-medium mb-1">Leads slip through the cracks because nobody followed up in time</p>
              <p class="text-muted-foreground text-sm">Every missed follow-up is revenue walking out the door.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <div>
              <p class="font-medium mb-1">You know AI can help but do not know where to start</p>
              <p class="text-muted-foreground text-sm">Generic tools do not fit your workflows. You need something built for how your team actually operates.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SOLUTION -->
    <section class="py-20 px-6 bg-card">
      <div class="max-w-3xl mx-auto">
        <p class="text-emerald-400 text-sm font-medium tracking-wide uppercase mb-4">The solution</p>
        <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-8">
          Custom AI systems built<br/>
          <span class="text-muted-foreground">around your exact workflows.</span>
        </h2>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-emerald-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div>
              <p class="font-medium mb-1">AI assistants that handle customer queries, qualify leads, and book meetings</p>
              <p class="text-muted-foreground text-sm">Working 24/7 so your team can focus on closing, not qualifying.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-emerald-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div>
              <p class="font-medium mb-1">Automated workflows for CRM, outreach, reporting, and data entry</p>
              <p class="text-muted-foreground text-sm">End-to-end automation. Not another tool to manage.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-emerald-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div>
              <p class="font-medium mb-1">Deployed in 4 to 6 weeks, monitored and maintained for you</p>
              <p class="text-muted-foreground text-sm">We build, deploy, and own it. You just see the results.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SOCIAL PROOF: Results -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <p class="text-emerald-400 text-sm font-medium tracking-wide uppercase mb-4 text-center">Real results</p>
        <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-12 text-center">
          What our clients are seeing
        </h2>

        <div class="grid sm:grid-cols-3 gap-6 mb-12">
          <div class="bg-card border border-border rounded-2xl p-6 text-center">
            <div class="text-3xl md:text-4xl font-bold text-emerald-400 mb-2">15+</div>
            <div class="text-sm text-muted-foreground">hours saved per person, per week</div>
          </div>
          <div class="bg-card border border-border rounded-2xl p-6 text-center">
            <div class="text-3xl md:text-4xl font-bold text-emerald-400 mb-2">85.4%</div>
            <div class="text-sm text-muted-foreground">reply rate on automated outreach</div>
          </div>
          <div class="bg-card border border-border rounded-2xl p-6 text-center">
            <div class="text-3xl md:text-4xl font-bold text-emerald-400 mb-2">4-6</div>
            <div class="text-sm text-muted-foreground">weeks from call to live system</div>
          </div>
        </div>

        <!-- Testimonial cards -->
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-card border border-border rounded-2xl p-6">
            <div class="flex items-center gap-1 mb-3">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <p class="text-foreground mb-4 leading-relaxed">
              "Replaced our entire 8-step manual booking form with an AI system that gathers info conversationally and completes bookings automatically. Transformed our operations."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-muted flex items-center justify-center text-xs font-bold text-muted-foreground">LC</div>
              <div>
                <div class="text-sm font-medium">Logistics Company</div>
                <div class="text-xs text-muted-foreground">Air Cargo & Freight</div>
              </div>
            </div>
          </div>

          <div class="bg-card border border-border rounded-2xl p-6">
            <div class="flex items-center gap-1 mb-3">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <p class="text-foreground mb-4 leading-relaxed">
              "85.4% reply rate across 259 automated contacts. The system handled connection requests, messaging, and follow-ups while we focused on closing deals."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-muted flex items-center justify-center text-xs font-bold text-muted-foreground">RF</div>
              <div>
                <div class="text-sm font-medium">Recruiting Firm</div>
                <div class="text-xs text-muted-foreground">Executive Search</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="py-20 px-6 bg-card">
      <div class="max-w-3xl mx-auto">
        <p class="text-emerald-400 text-sm font-medium tracking-wide uppercase mb-4 text-center">What you will receive</p>
        <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-10 text-center">
          Inside the free playbook
        </h2>

        <div class="space-y-4">
          <div class="flex items-start gap-4 bg-background border border-border rounded-xl p-5">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
              <span class="text-emerald-400 font-bold text-sm">1</span>
            </div>
            <div>
              <p class="font-medium">The AI Automation Priority Matrix</p>
              <p class="text-sm text-muted-foreground">Identify exactly which tasks to automate first for maximum time savings.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 bg-background border border-border rounded-xl p-5">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
              <span class="text-emerald-400 font-bold text-sm">2</span>
            </div>
            <div>
              <p class="font-medium">Before/After time breakdowns from real clients</p>
              <p class="text-sm text-muted-foreground">See exactly how many hours each system saves per person, per week.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 bg-background border border-border rounded-xl p-5">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
              <span class="text-emerald-400 font-bold text-sm">3</span>
            </div>
            <div>
              <p class="font-medium">The 5 systems every business should automate first</p>
              <p class="text-sm text-muted-foreground">CRM updates, lead enrichment, outreach, reporting, and data entry.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 bg-background border border-border rounded-xl p-5">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
              <span class="text-emerald-400 font-bold text-sm">4</span>
            </div>
            <div>
              <p class="font-medium">Custom system blueprint for your business</p>
              <p class="text-sm text-muted-foreground">A tailored recommendation based on your industry and team size.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BEFORE / AFTER TABLE -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <p class="text-emerald-400 text-sm font-medium tracking-wide uppercase mb-4 text-center">The numbers</p>
        <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-4 text-center">
          Where the hours go
        </h2>
        <p class="text-muted-foreground text-center mb-10">Per person, per week. Multiply by your team size.</p>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-border text-sm text-muted-foreground">
                <th class="py-4 pr-6 font-medium">Task</th>
                <th class="py-4 pr-6 font-medium text-red-400">Before</th>
                <th class="py-4 pr-6 font-medium text-emerald-400">After</th>
                <th class="py-4 font-medium">Saved</th>
              </tr>
            </thead>
            <tbody class="text-sm md:text-base">
