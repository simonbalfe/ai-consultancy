---
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE, CALENDLY_URL } from "../consts";
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>

  <style>
    /* Scroll reveal base */
    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Slide from left */
    .reveal-left {
      opacity: 0;
      transform: translateX(-40px);
      transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .reveal-left.is-visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* Slide from right */
    .reveal-right {
      opacity: 0;
      transform: translateX(40px);
      transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .reveal-right.is-visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* Scale up */
    .reveal-scale {
      opacity: 0;
      transform: scale(0.92);
      transition: opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .reveal-scale.is-visible {
      opacity: 1;
      transform: scale(1);
    }

    /* Stagger children delays */
    .stagger > *:nth-child(1) { transition-delay: 0s; }
    .stagger > *:nth-child(2) { transition-delay: 0.1s; }
    .stagger > *:nth-child(3) { transition-delay: 0.15s; }
    .stagger > *:nth-child(4) { transition-delay: 0.2s; }
    .stagger > *:nth-child(5) { transition-delay: 0.25s; }
    .stagger > *:nth-child(6) { transition-delay: 0.3s; }

    /* Table row reveal */
    .reveal-row {
      opacity: 0;
      transform: translateX(-20px);
      transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    .reveal-row.is-visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* CTA glow pulse */
    @keyframes glow-pulse {
      0%, 100% { box-shadow: 0 0 20px rgba(var(--accent-rgb, 139 92 246), 0.3); }
      50% { box-shadow: 0 0 40px rgba(var(--accent-rgb, 139 92 246), 0.5), 0 0 60px rgba(var(--accent-rgb, 139 92 246), 0.2); }
    }
    .cta-glow {
      animation: glow-pulse 3s ease-in-out infinite;
    }

    /* Hero text fade-in stagger */
    @keyframes hero-fade-up {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-animate > *:nth-child(1) { animation: hero-fade-up 0.8s ease-out 0.1s both; }
    .hero-animate > *:nth-child(2) { animation: hero-fade-up 0.8s ease-out 0.3s both; }
    .hero-animate > *:nth-child(3) { animation: hero-fade-up 0.8s ease-out 0.5s both; }

    /* Progress bar fill */
    .progress-fill {
      width: 0;
      transition: width 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .progress-fill.is-visible {
      width: var(--fill-width);
    }

    /* Logo ticker */
    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .ticker-track {
      animation: ticker 30s linear infinite;
    }
    .ticker-track:hover {
      animation-play-state: paused;
    }

    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .ticker-track { animation: none; }
      .reveal, .reveal-left, .reveal-right, .reveal-scale, .reveal-row {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .hero-animate > * {
        animation: none !important;
        opacity: 1;
      }
      .cta-glow { animation: none; }
      .progress-fill { width: var(--fill-width); transition: none; }
    }
  </style>

  <!-- NAV -->
  <nav class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] md:w-auto">
    <div class="flex items-center justify-between md:justify-start gap-6 px-5 py-3 rounded-full border border-white/10 bg-white/5 backdrop-blur-md">
      <a href="/" class="flex items-center gap-2">
        <img src="/images/layout/hermesops-icon.svg" alt="HermesOps" class="h-7 w-7 brightness-0 invert" />
        <span class="text-lg font-semibold tracking-tight text-foreground">HermesOps</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm text-muted-foreground">
        <a href="#services" class="hover:text-foreground transition-colors">Services</a>
        <a href="#process" class="hover:text-foreground transition-colors">Process</a>
        <a href="#results" class="hover:text-foreground transition-colors">Results</a>
        <a href="#faq" class="hover:text-foreground transition-colors">FAQ</a>
      </div>
      <a
        href={CALENDLY_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-block bg-accent text-accent-foreground px-5 py-2 rounded-full text-sm font-normal hover:opacity-90 transition-opacity"
      >
        Book a call
      </a>
      <button id="mobile-menu-btn" class="md:hidden text-foreground" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-2 rounded-2xl border border-white/10 bg-background/95 backdrop-blur-md p-6 flex flex-col gap-4">
      <a href="#services" class="text-foreground text-base">Services</a>
      <a href="#process" class="text-foreground text-base">Process</a>
      <a href="#results" class="text-foreground text-base">Results</a>
      <a href="#faq" class="text-foreground text-base">FAQ</a>
      <a
        href={CALENDLY_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent text-accent-foreground px-5 py-3 rounded-full text-sm font-normal text-center hover:opacity-90 transition-opacity"
      >
        Book a call
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative pt-40 pb-24 px-6 min-h-[90vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/homepage/hero-dashboard.jpg"
        alt=""
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-background/70 via-background/60 to-background"></div>
    </div>
    <div class="relative max-w-4xl mx-auto text-center hero-animate">
      <h1 class="text-5xl md:text-7xl font-normal tracking-tight leading-[1.1] mb-6">
        AI systems that<br/>
        <span class="italic font-extralight text-muted-foreground">work while you sleep.</span>
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground font-light max-w-2xl mx-auto mb-10">
        We build custom AI that automates your operations, saves your team hours every week, and scales with your business.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="cta-glow bg-accent text-accent-foreground px-8 py-3.5 rounded-full text-base font-normal hover:opacity-90 transition-opacity"
        >
          Book your free consultation
        </a>
        <a
          href="#services"
          class="text-muted-foreground hover:text-foreground transition-colors text-base"
        >
          See what we build &darr;
        </a>
      </div>
    </div>
  </section>

  <!-- TOOLS & INTEGRATIONS -->
  <section class="py-16 px-6 border-t border-border overflow-hidden reveal">
    <div class="max-w-7xl mx-auto">
      <p class="text-center text-sm text-muted-foreground mb-8">Built with the tools your team already uses</p>
      <div class="relative">
        <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-background to-transparent z-10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-background to-transparent z-10"></div>
        <div class="overflow-hidden">
          <div class="ticker-track flex items-center gap-12 w-max">
            <!-- First set -->
            <img src="/images/logos/make.svg" alt="Make.com" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/n8n.svg" alt="n8n" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/zapier.svg" alt="Zapier" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/hubspot.svg" alt="HubSpot" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/salesforce.svg" alt="Salesforce" class="h-8 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/slack.svg" alt="Slack" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/notion.svg" alt="Notion" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/airtable.svg" alt="Airtable" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/openai.svg" alt="OpenAI" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/stripe.svg" alt="Stripe" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/twilio.svg" alt="Twilio" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/google-workspace.svg" alt="Google Workspace" class="h-8 opacity-70 hover:opacity-100 transition-opacity" />
            <!-- Duplicate set for seamless loop -->
            <img src="/images/logos/make.svg" alt="Make.com" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/n8n.svg" alt="n8n" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/zapier.svg" alt="Zapier" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/hubspot.svg" alt="HubSpot" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/salesforce.svg" alt="Salesforce" class="h-8 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/slack.svg" alt="Slack" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/notion.svg" alt="Notion" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/airtable.svg" alt="Airtable" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/openai.svg" alt="OpenAI" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/stripe.svg" alt="Stripe" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/twilio.svg" alt="Twilio" class="h-7 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="/images/logos/google-workspace.svg" alt="Google Workspace" class="h-8 opacity-70 hover:opacity-100 transition-opacity" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="reveal">
        <p class="text-accent text-sm font-light tracking-widest uppercase mb-4">What we build</p>
        <h2 class="text-3xl md:text-5xl font-normal tracking-tight mb-6">
          Custom AI systems.<br/>
          <span class="text-muted-foreground">Not templates.</span>
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mb-16">
          Every business is different. We diagnose your workflows, find the bottlenecks, and build systems tailored to how your team actually works.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 stagger">
        <div class="reveal bg-card border border-border rounded-2xl p-8 hover:border-accent/30 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="text-xl font-normal mb-3">AI Assistants & Chatbots</h3>
          <p class="text-muted-foreground font-light leading-relaxed">
            Intelligent conversational systems that handle customer queries, qualify leads, and book meetings automatically.
          </p>
        </div>

        <div class="reveal bg-card border border-border rounded-2xl p-8 hover:border-accent/30 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="text-xl font-normal mb-3">Workflow Automation</h3>
          <p class="text-muted-foreground font-light leading-relaxed">
            End-to-end automation of repetitive processes. CRM updates, data entry, reporting, outreach, and follow-ups on autopilot.
          </p>
        </div>

        <div class="reveal bg-card border border-border rounded-2xl p-8 hover:border-accent/30 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-normal mb-3">Data & Intelligence</h3>
          <p class="text-muted-foreground font-light leading-relaxed">
            AI-powered analytics, lead scoring, candidate matching, and document processing that turns raw data into decisions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BEFORE / AFTER -->
  <section class="py-24 px-6 bg-card">
    <div class="max-w-7xl mx-auto">
      <div class="reveal">
        <p class="text-accent text-sm font-light tracking-widest uppercase mb-4">Before & After</p>
        <h2 class="text-3xl md:text-5xl font-normal tracking-tight mb-4">
          Where the hours go.
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mb-12">
          These are the workflows we automate first. The numbers are per person, per week.
        </p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-border text-sm text-muted-foreground">
              <th class="py-4 pr-8 font-light">Task</th>
              <th class="py-4 pr-8 font-light text-red-400">Before</th>
              <th class="py-4 pr-8 font-light text-emerald-400">After</th>
              <th class="py-4 font-light text-accent">Time saved</th>
            </tr>
          </thead>
          <tbody class="text-base" id="table-body">
            <tr class="border-b border-border reveal-row" style="transition-delay: 0s;">
              <td class="py-4 pr-8">CRM updates after meetings</td>
              <td class="py-4 pr-8 text-red-400">4h 00m</td>
              <td class="py-4 pr-8 text-emerald-400">0h 45m</td>
              <td class="py-4 text-accent font-light">3h 15m</td>
            </tr>
            <tr class="border-b border-border reveal-row" style="transition-delay: 0.08s;">
              <td class="py-4 pr-8">Pre-meeting research & briefs</td>
              <td class="py-4 pr-8 text-red-400">2h 30m</td>
              <td class="py-4 pr-8 text-emerald-400">0h 20m</td>
              <td class="py-4 text-accent font-light">2h 10m</td>
            </tr>
            <tr class="border-b border-border reveal-row" style="transition-delay: 0.16s;">
              <td class="py-4 pr-8">Lead enrichment & scoring</td>
              <td class="py-4 pr-8 text-red-400">2h 00m</td>
              <td class="py-4 pr-8 text-emerald-400">0h 15m</td>
              <td class="py-4 text-accent font-light">1h 45m</td>
            </tr>
            <tr class="border-b border-border reveal-row" style="transition-delay: 0.24s;">
              <td class="py-4 pr-8">Outreach & follow-ups</td>
              <td class="py-4 pr-8 text-red-400">3h 00m</td>
              <td class="py-4 pr-8 text-emerald-400">0h 20m</td>
              <td class="py-4 text-accent font-light">2h 40m</td>
            </tr>
            <tr class="border-b border-border reveal-row" style="transition-delay: 0.32s;">
              <td class="py-4 pr-8">Content creation & publishing</td>
              <td class="py-4 pr-8 text-red-400">3h 30m</td>
              <td class="py-4 pr-8 text-emerald-400">0h 30m</td>
              <td class="py-4 text-accent font-light">3h 00m</td>
            </tr>
            <tr class="reveal-row" style="transition-delay: 0.4s;">
              <td class="py-4 pr-8">Data entry & reporting</td>
              <td class="py-4 pr-8 text-red-400">2h 30m</td>
              <td class="py-4 pr-8 text-emerald-400">0h 20m</td>
              <td class="py-4 text-accent font-light">2h 10m</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="reveal mt-8">
        <p class="text-muted-foreground text-sm italic">
          That is <span class="text-accent font-normal not-italic" data-count-to="15" data-suffix="+">0</span> hours back per person, per week. Multiply by your team size.
        </p>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process" class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="reveal">
        <p class="text-accent text-sm font-light tracking-widest uppercase mb-4">How it works</p>
        <h2 class="text-3xl md:text-5xl font-normal tracking-tight mb-16">
          From call to deployed.<br/>
          <span class="text-muted-foreground">In weeks, not months.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-4 gap-8 stagger">
        <div class="reveal">
          <div class="w-10 h-10 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-normal mb-5">1</div>
          <h3 class="text-lg font-normal mb-2">Discovery</h3>
          <p class="text-muted-foreground font-light leading-relaxed">
            30-minute call. We map where your time goes and find the highest-impact bottlenecks.
          </p>
        </div>
        <div class="reveal">
          <div class="w-10 h-10 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-normal mb-5">2</div>
          <h3 class="text-lg font-normal mb-2">Design</h3>
          <p class="text-muted-foreground font-light leading-relaxed">
            We scope the system, define the integrations, and agree on exactly what gets built. No code until you approve.
          </p>
        </div>
        <div class="reveal">
          <div class="w-10 h-10 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-normal mb-5">3</div>
          <h3 class="text-lg font-normal mb-2">Build</h3>
          <p class="text-muted-foreground font-light leading-relaxed">
            We build, test, and iterate. You see progress weekly. First system live in 4 to 6 weeks.
          </p>
        </div>
        <div class="reveal">
          <div class="w-10 h-10 rounded-full bg-accent/10 text-accent flex items-center justify-center text-sm font-normal mb-5">4</div>
          <h3 class="text-lg font-normal mb-2">Deploy & Support</h3>
          <p class="text-muted-foreground font-light leading-relaxed">
            Deployed into your stack. Monitored, maintained, and improved as your operations evolve.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTS -->
  <section id="results" class="py-24 px-6 bg-card">
    <div class="max-w-7xl mx-auto">
      <div class="reveal">
        <p class="text-accent text-sm font-light tracking-widest uppercase mb-4">Results</p>
        <h2 class="text-3xl md:text-5xl font-normal tracking-tight mb-16">
          Real systems.<br/>
          <span class="text-muted-foreground">Real hours recovered.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-16 stagger" id="stats-grid">
        <div class="reveal-scale bg-background border border-border rounded-2xl p-8">
          <div class="text-4xl font-light text-accent mb-2" data-count-to="15" data-suffix="+">0</div>
          <div class="text-muted-foreground">hours saved per person, per week</div>
          <div class="mt-4 h-1.5 bg-muted rounded-full overflow-hidden">
            <div class="progress-fill h-full bg-accent rounded-full" style="--fill-width: 85%;"></div>
          </div>
        </div>
        <div class="reveal-scale bg-background border border-border rounded-2xl p-8">
          <div class="text-4xl font-light text-accent mb-2" data-count-to="4" data-count-end="6" data-separator="-">0</div>
          <div class="text-muted-foreground">weeks from call to live system</div>
          <div class="mt-4 h-1.5 bg-muted rounded-full overflow-hidden">
            <div class="progress-fill h-full bg-accent rounded-full" style="--fill-width: 60%;"></div>
          </div>
        </div>
        <div class="reveal-scale bg-background border border-border rounded-2xl p-8">
          <div class="text-4xl font-light text-accent mb-2" data-count-to="100" data-suffix="%">0</div>
          <div class="text-muted-foreground">custom built for your workflows</div>
          <div class="mt-4 h-1.5 bg-muted rounded-full overflow-hidden">
            <div class="progress-fill h-full bg-accent rounded-full" style="--fill-width: 100%;"></div>
          </div>
        </div>
      </div>

      <!-- Case study carousel -->
